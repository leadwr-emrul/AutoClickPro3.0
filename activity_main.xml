<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ Auto Click Pro"
            android:textColor="#58A6FF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"/>

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#161B22"
            android:padding="12dp"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="STATUS"
                android:textColor="#8B949E"
                android:textSize="10sp"
                android:letterSpacing="0.15"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_service_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="○ Service OFF"
                        android:textColor="#FF6B6B"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tv_connection_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="○ Disconnected"
                        android:textColor="#FF6B6B"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_automation_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="○ Stopped"
                    android:textColor="#FF6B6B"
                    android:textSize="13sp"
                    android:gravity="center_vertical"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Profile Selector -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile:"
                android:textColor="#8B949E"
                android:textSize="13sp"
                android:layout_marginEnd="8dp"/>

            <Spinner
                android:id="@+id/spinner_profile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#161B22"
                android:popupBackground="#21262D"/>
        </LinearLayout>

        <!-- Main Control Buttons -->
        <Button
            android:id="@+id/btn_start_stop"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="START"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:backgroundTint="#238636"
            android:layout_marginTop="12dp"/>

        <!-- Action Buttons Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_open_accessibility"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Enable Service"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:backgroundTint="#1F6FEB"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_overlay"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Floating Panel"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:backgroundTint="#388BFD"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Action Buttons Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_positions"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="⚙ Positions"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:backgroundTint="#21262D"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_test"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="▶ Test Signal"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:backgroundTint="#6E40C9"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_settings"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="⚙ Settings"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:backgroundTint="#21262D"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Log Panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LIVE LOG"
                android:textColor="#8B949E"
                android:textSize="10sp"
                android:letterSpacing="0.15"/>

            <Button
                android:id="@+id/btn_clear_log"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Clear"
                android:textColor="#8B949E"
                android:textSize="10sp"
                android:backgroundTint="#21262D"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_logs"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:background="#0D1117"
            android:padding="8dp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>
</ScrollView>
